<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blogs - B4Blog</title>
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="/stylesheets/output.css" />
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
</head>

<body class="bg-gradient-to-r from-blue-600 to-purple-600 min-h-screen text-white font-sans antialiased">
    <!-- Navigation Bar -->
    <nav class="bg-purple-900/90 backdrop-blur-md sticky top-0 z-30 p-4 shadow-2xl flex justify-between items-center px-6">
        <a href="/" class="md:text-3xl text-2xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-indigo-300 to-pink-400 hover:scale-105 transition transform duration-300">
            B4Blog
        </a>
        <div class="flex items-center gap-6">
            <a href="/blogs" class="text-white font-semibold hover:text-indigo-300 transition md:text-lg text-base">
                Blogs
            </a>
            <% if (user) { %>
                <a href="/profile" class="text-white font-semibold hover:text-indigo-300 transition md:text-lg text-base">
                    Profile
                </a>
                <a href="/logout"
                    class="flex items-center bg-red-600 hover:bg-red-700 px-4 py-2 rounded-full transition transform hover:scale-105 shadow-lg">
                    <i class="fas fa-sign-out-alt mr-2"></i> Logout
                </a>
            <% } else { %>
                <a href="/login" class="text-white font-semibold hover:text-indigo-300 transition md:text-lg text-base">
                    Login
                </a>
                <a href="/signup" class="text-white font-semibold hover:text-indigo-300 transition md:text-lg text-base">
                    Signup
                </a>
            <% } %>
        </div>
    </nav>

    <main class="container mx-auto md:p-12 p-6">
        <!-- Hero Section: Latest Blog -->
        <% if (latestPost) { %>
            <section class="mb-16">
                <h2 class="text-3xl md:text-4xl font-extrabold text-center mb-8 bg-clip-text text-transparent bg-gradient-to-r from-indigo-200 to-pink-300">
                    Latest Blog
                </h2>
                <a href="/post/<%= latestPost._id %>"
                    class="block bg-gradient-to-br from-white to-indigo-50/80 rounded-3xl p-8 shadow-2xl hover:shadow-3xl transition-all duration-500 max-w-4xl mx-auto border border-indigo-300/30 animate-fade-in">
                    <div class="flex flex-col sm:flex-row gap-6">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="bg-indigo-100 text-indigo-800 text-sm font-semibold px-4 py-1 rounded-full hover:bg-indigo-200 transition">
                                    <%= latestPost.category %>
                                </span>
                                <span class="text-gray-500 font-medium text-sm">
                                    <%= new Date(latestPost.postedAt).toLocaleDateString() %>
                                </span>
                            </div>
                            <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4 hover:text-indigo-700 transition">
                                <%= latestPost.content.substring(0, 60) + (latestPost.content.length > 60 ? '...' : '') %>
                            </h3>
                            <p class="text-gray-700 text-base md:text-lg leading-relaxed mb-4">
                                <%= latestPost.content.substring(0, 200) + (latestPost.content.length > 200 ? '...' : '') %>
                            </p>
                            <span class="text-gray-600 font-semibold text-base hover:text-indigo-600 transition">
                                @<%= latestPost.author.userName %>
                            </span>
                        </div>
                        <div class="w-full sm:w-1/3 h-48 bg-gray-200 rounded-xl overflow-hidden">
                            <!-- Placeholder for future image -->
                            <div class="w-full h-full bg-gradient-to-br from-indigo-200 to-pink-200 flex items-center justify-center text-gray-500">
                                Image Coming Soon
                            </div>
                        </div>
                    </div>
                </a>
            </section>
        <% } %>

        <!-- Search and Filter -->
        <section class="mb-12 max-w-3xl mx-auto">
            <form action="/blogs" method="GET" class="flex flex-col sm:flex-row gap-4 bg-white bg-opacity-95 rounded-2xl p-4 shadow-lg">
                <div class="relative flex-1">
                    <input type="text" name="search" value="<%= search || '' %>" placeholder="Search blogs by keyword..."
                        class="w-full p-4 pr-12 rounded-lg border border-gray-200 focus:outline-indigo-500 text-gray-900 text-base" />
                    <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-indigo-600">
                        <i class="fas fa-search text-lg"></i>
                    </button>
                </div>
                <select name="category" onchange="this.form.submit()"
                    class="p-4 rounded-lg border border-gray-200 focus:outline-indigo-500 text-gray-900 text-base">
                    <option value="" <%= !category ? 'selected' : '' %>>All Categories</option>
                    <option value="Tech" <%= category === 'Tech' ? 'selected' : '' %>>Tech</option>
                    <option value="Food" <%= category === 'Food' ? 'selected' : '' %>>Food</option>
                    <option value="Software" <%= category === 'Software' ? 'selected' : '' %>>Software</option>
                    <option value="Lifestyle" <%= category === 'Lifestyle' ? 'selected' : '' %>>Lifestyle</option>
                    <option value="Travel" <%= category === 'Travel' ? 'selected' : '' %>>Travel</option>
                    <option value="Health" <%= category === 'Health' ? 'selected' : '' %>>Health</option>
                    <option value="Education" <%= category === 'Education' ? 'selected' : '' %>>Education</option>
                    <option value="Others" <%= category === 'Others' ? 'selected' : '' %>>Others</option>
                </select>
            </form>
        </section>

        <!-- Blog List -->
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-h-[48rem] overflow-y-auto relative blog-list">
            <% if (posts && posts.length > 0) { %>
                <% posts.forEach((post, index) => { %>
                    <a href="/post/<%= post._id %>"
                        class="bg-white bg-opacity-95 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 border animate-fade-in"
                        style="animation-delay: <%= index * 0.1 %>s; border-color: <%= post.category === 'Tech' ? 'rgba(59, 130, 246, 0.3)' : post.category === 'Food' ? 'rgba(34, 197, 94, 0.3)' : post.category === 'Software' ? 'rgba(168, 85, 247, 0.3)' : post.category === 'Lifestyle' ? 'rgba(236, 72, 153, 0.3)' : post.category === 'Travel' ? 'rgba(249, 115, 22, 0.3)' : post.category === 'Health' ? 'rgba(239, 68, 68, 0.3)' : post.category === 'Education' ? 'rgba(234, 179, 8, 0.3)' : 'rgba(99, 102, 241, 0.3)' %>">
                        <div class="mb-4">
                            <span class="bg-indigo-100 text-indigo-800 text-xs md:text-sm font-semibold px-3 py-1 rounded-full hover:bg-indigo-200 transition">
                                <%= post.category %>
                            </span>
                        </div>
                        <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-3 hover:text-indigo-700 transition">
                            <%= post.content.substring(0, 50) + (post.content.length > 50 ? '...' : '') %>
                        </h3>
                        <p class="text-gray-700 text-base md:text-lg leading-relaxed mb-4">
                            <%= post.content.substring(0, 120) + (post.content.length > 120 ? '...' : '') %>
                        </p>
                        <div class="flex items-center justify-between text-sm text-gray-600">
                            <span class="font-semibold hover:text-indigo-600 transition">
                                @<%= post.author.userName %>
                            </span>
                            <span class="text-gray-500">
                                <%= new Date(post.postedAt).toLocaleDateString() %>
                            </span>
                        </div>
                    </a>
                <% }); %>
            <% } else { %>
                <p class="text-white text-center text-lg col-span-full mt-12">
                    No blogs found. Try a different search or category!
                </p>
            <% } %>
        </section>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="flex justify-center items-center gap-4 mt-12">
                <% if (page > 1) { %>
                    <a href="/blogs?page=<%= page - 1 %><%= category ? '&category=' + category : '' %><%= search ? '&search=' + search : '' %>"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white py-2 px-4 rounded-full font-semibold transition transform hover:scale-105 flex items-center gap-2">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                <% } %>
                <span class="text-white font-semibold text-lg">
                    Page <%= page %> of <%= totalPages %>
                </span>
                <% if (page < totalPages) { %>
                    <a href="/blogs?page=<%= page + 1 %><%= category ? '&category=' + category : '' %><%= search ? '&search=' + search : '' %>"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white py-2 px-4 rounded-full font-semibold transition transform hover:scale-105 flex items-center gap-2">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                <% } %>
            </div>
        <% } %>
    </main>

    <!-- Custom Styling -->
    <style>
        .blog-list::-webkit-scrollbar {
            display: none;
        }
        .blog-list {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }
        .blog-list.overflow-y-auto::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3rem;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.4), transparent);
        }
        @keyframes fade-in {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fade-in 0.6s ease-out forwards;
        }
    </style>
</body>

</html>