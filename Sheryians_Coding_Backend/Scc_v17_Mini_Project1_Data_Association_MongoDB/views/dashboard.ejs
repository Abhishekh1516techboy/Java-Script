<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Dashboard</title>
        <link rel="stylesheet" href="/stylesheets/output.css">
    </head>

    <body class="bg-gray-100 font-sans">
        <!-- Navigation Bar -->
        <nav class="bg-blue-600 text-white p-2 shadow-md">
            <div class="container mx-auto flex justify-between items-center">
                <h1 class="text-xl sm:text-2xl font-bold">Dashboard</h1>
                <div class=" space-x-4">
                    <a href="/logout"
                        class="bg-red-600 hover:bg-red-700 text-white font-bold py-1 px-4 rounded transition-colors">Logout</a>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="container mx-auto mt-6 sm:mt-8 px-4 sm:px-6 lg:px-8">
            <div class="bg-white rounded-lg shadow-md p-6 sm:p-8 max-w-full sm:max-w-md mx-auto">
                <!-- if New User registered show this message -->
                <% if (isNewUser) { %>
                    <h3 class="text-green-500 text-xl">Welcome! You've successfully registered.</h3>
                    <h1 class="text-xl sm:text-2xl font-bold text-gray-900">
                        <%= user && user.userName ? `Mr.${user.userName}` : '' %>
                    </h1>
                    <% } %>

                        <!-- if User Login show this message -->
                        <% if (!isNewUser) { %>
                            <h1 class="text-sm sm:text-xl font-bold mb-4 text-gray-900">
                                <%= user && user.userName ? `Welcome, ${user.userName}` : '' %>
                            </h1>
                            <% } %>
                                <p class="text-gray-600 sm:text-lg mb-2 text-xs">Email: <%= user ? user.email : "" %>
                                </p>
            </div>
        </div>
    </body>

</html>