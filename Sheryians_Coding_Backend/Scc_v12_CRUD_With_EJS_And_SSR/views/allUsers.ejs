<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Backend NodeJS All Users</title>
        <link rel="stylesheet" href="/stylesheets/style.css">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    </head>

    <body class="bg-zinc-900 min-h-screen text-white py-10 px-3">
        <div class="max-w-4xl  mx-auto">
            <h1 class="text-3xl font-bold mb-8 text-center">User's List</h1>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 pb-4">
                <% users.forEach(user=> { %>
                    <a href="/user/<%= encodeURIComponent(user.email) %>" target="_parent" class="block">
                        <div
                            class="flex items-center gap-4 bg-zinc-800 hover:bg-zinc-900 transition-all border border-zinc-700 rounded-xl p-4 shadow-lg">
                            <img src="<%= user.imageUrl %>" alt="User Avatar"
                                class="w-16 h-16 rounded-full border-2 border-indigo-500 object-cover" />
                            <div>
                                <h2 class="text-lg font-semibold">
                                    <%= user.name %>
                                </h2>
                                <p class="text-zinc-300 text-sm">
                                    <%= user.email %>
                                </p>
                            </div>
                        </div>
                    </a>
                    <% }) %>
            </div>

            <% if (users.length===0) { %>
                <p class="text-center mt-10 text-zinc-400">No users found.</p>
                <% } %>
        </div>
    </body>

</html>